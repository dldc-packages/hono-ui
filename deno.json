{
  "name": "@dldc/hono-ui",
  "version": "2.0.5",
  "exports": {
    ".": "./mod.ts"
  },
  "imports": {
    "@dldc/css-builder": "jsr:@dldc/css-builder@^1.6.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "hono": "jsr:@hono/hono@^4.12.19",
    "lucide-static": "npm:lucide-static@^1.16.0",
    "type-fest": "npm:type-fest@^5.6.0"
  },
  "tasks": {
    "bump": "deno run -A jsr:@mys/bump@1",
    "deps:outdated": "deno outdated",
    "deps:update": "deno outdated --update --latest --interactive",
    "check": "deno fmt --check . && deno check . && deno lint . ",
    "docs:dev": "deno run -A --unstable-kv --watch ./docs/main.tsx",
    "script:css-properties": "deno run -A ./scripts/cssProperties.ts"
  },
  "fmt": {
    "lineWidth": 140
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
