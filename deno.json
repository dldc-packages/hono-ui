{
  "name": "@dldc/hono-ui",
  "version": "1.1.2",
  "exports": {
    ".": "./mod.ts"
  },
  "imports": {
    "@dldc/css-builder": "jsr:@dldc/css-builder@^1.5.0",
    "hono": "jsr:@hono/hono@^4.12.14",
    "type-fest": "npm:type-fest@^5.6.0"
  },
  "tasks": {
    "bump": "deno run -A jsr:@mys/bump@1",
    "deps:outdated": "deno outdated",
    "deps:update": "deno outdated --update --latest --interactive",
    "check": "deno fmt --check . && deno lint . && deno check **/*.ts",
    "docs:dev": "deno run -A --unstable-kv --watch ./docs/main.tsx"
  },
  "fmt": {
    "lineWidth": 140
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
